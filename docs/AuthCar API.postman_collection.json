  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Gerar Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "",
                  "if (jsonData && jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('bearerToken', jsonData.data.token);",
                  "    console.log('✅ Token capturado e salvo com sucesso!');",
                  "    console.log('🔑 Token:', jsonData.data.token);",
                  "    console.log('👤 Login:', jsonData.data.login);",
                  "    console.log('⏱️ Expira em:', jsonData.data.expiraEm);",
                  "} else {",
                  "    console.error('❌ Falha ao capturar o token. Verifique a resposta da API.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/AuthCar/Auth/GerarToken",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "AuthCar",
                "Auth",
                "GerarToken"
              ]
            }
          },
          "response": []
        }
      ]
    },
